# Opsfield Systems — environment variables.
# Copy to .env.local for local dev, and set these in the production host.
# NOTE: SITE_MODE, SITE_URL, and the SEO routes (robots.txt, sitemap.xml,
# canonical) are baked at BUILD time — set them before `next build` in prod.

# --- Indexing gate -----------------------------------------------------------
# "production" flips the site to index,follow + Allow:/ + a live sitemap.
# Anything else (or unset) = preview: noindex, Disallow:/, empty sitemap.
# If this is not "production" on the live deploy, the site will be de-indexed.
SITE_MODE=preview

# Absolute production origin, no trailing slash (e.g. https://opsfieldsystems.com).
# Drives canonical, OG/JSON-LD URLs, and sitemap <loc>. If unset it falls back to
# VERCEL_URL (a *.vercel.app preview host) and then http://localhost:3000 — both
# WRONG for production canonical. Always set the real domain in prod.
SITE_URL=

# --- Form backend (Resend) ---------------------------------------------------
# Delivery is gated on RESEND_API_KEY (not SITE_MODE) — leads send even on a
# noindex deploy. No key in production = the form shows the email fallback.
RESEND_API_KEY=
# Where diagnostic requests are delivered (a real, monitored inbox).
DIAGNOSTIC_RECIPIENT_EMAIL=opsfieldsystems@gmail.com
# Sender. Until a domain is verified in Resend, only "onboarding@resend.dev"
# works, and it can ONLY deliver to the Resend account's own email address.
# Once you own a domain: verify it in Resend, then use e.g.
# "Opsfield Systems <hello@yourdomain.com>".
DIAGNOSTIC_FROM_EMAIL=Opsfield Systems <onboarding@resend.dev>

# Optional backup sink — every valid lead is also POSTed here as JSON (Zapier /
# Make / n8n / Google Apps Script webhook), so a lead survives an email failure.
LEAD_WEBHOOK_URL=

# --- Analytics (GA4) ---------------------------------------------------------
# The only NEXT_PUBLIC_ value. Empty keeps analytics off. GA4 loads only after
# cookie consent AND when SITE_MODE=production.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
