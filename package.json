{
  "name": "opsfield-systems",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check": "npm run lint && npx tsc --noEmit && npm run build",
    "test:contracts": "npx playwright test tests/contracts/",
    "test:e2e": "npx playwright test tests/e2e/",
    "test:visual": "npx playwright test tests/visual/",
    "test:visual:update": "npx playwright test tests/visual/ --update-snapshots",
    "test": "npm run test:contracts && npm run test:e2e"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
